# Django Core Settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=generate-a-secure-random-string-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Firebase credentials string (Optional in dev, falls back to root JSON certificate if exists)
